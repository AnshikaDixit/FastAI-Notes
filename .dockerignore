# Exclude everything that doesn't belong in the Docker image

# Virtual environment (huge, not needed — Docker installs deps itself)
venv/
.venv/

# Python cache files
__pycache__/
*.py[cod]
*.pyo

# SQLite database (data lives in a Docker volume, not the image)
*.db
*.sqlite3

# Git history
.git/
.gitignore

# macOS junk
.DS_Store

# Environment variable files (secrets should never go into an image)
.env
.env.*

# Docs (not needed at runtime)
docs/

# IDE config
.vscode/
.idea/
